n <- 500
alpha <- 1.5
beta <- c(1,-1,-2)
eta <- c(0.5,0.6)
p <- length(beta)
q <- length(eta)
x <- matrix(rnorm(n*(p-1)),n,p-1)
x <- cbind(1,x)
w <- scale(matrix(runif(n*(q),-1,1),n,q)) # no intercept for logit!
censoring_time <- 100
results <- vector("list", num_reps)
# Compile the Stan model once to avoid re-compiling
stanmodel <- wb4
for (i in 1:num_reps) {
# Step 1: Generate a new dataset (modify this function to fit your simulation setup)
data <- geraMCM.WB(n, x, w, censoring_time=censoring_time , beta=beta, eta=eta, alpha=alpha,link="fglogit", tau=1.5, delta = 0.5)  # Custom function to simulate data
# Step 2: Prepare Stan data
stan_data <- list(
N = length(data$observed_time),
t = data$observed_time,
is_censored = data$status,
cured = data$cured,
x = data$x,
z = data$w,
M = dim(data$x)[2],
K = dim(data$w)[2]
)
# Step 3: Fit the model
fit <- sampling(stanmodel, data = stan_data, seed = 12345, chains = 1, iter = 2000,
init = 0, pars = c("betaU", "betaC", "sigma", "lambda_fg", "alpha_fg",  "lp__", "log_lik"))
# Step 4: Extract posterior estimates (Modify `extract_results()` as needed)
results[[i]] <- list(
fit = fit,
data = list(
X = data$x,
Z = data$w,
time = data$observed_time,
status = data$status,
event_time = data$event_time  # For quantile check
)
)
}
